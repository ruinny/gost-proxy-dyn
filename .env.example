# Gost 代理池环境变量配置模板
# 复制为 .env 并填入实际值

# ── Webshare API（多 Key 号池）─────────────────────────────
# 多个 API Key 用逗号分隔，组成号池提高吞吐量
# 从 https://proxy.webshare.io/dashboard/settings/general 获取
WEBSHARE_API_KEYS=key1,key2,key3

# ── SOCKS5 入口认证（客户端连接代理时使用）────────────────────
PROXY_USERNAME=proxyuser
PROXY_PASSWORD=your_strong_password_here

# ── 代理筛选配置 ──────────────────────────────────────────────
# 国家代码（ISO 3166-1 alpha-2），多个国家用连字符分隔，如 US-GB
# 使用 - 表示所有国家
PROXY_COUNTRY=US
# 最大使用代理节点数（从所有 Key 的合并池中截取）
MAX_PROXIES=50

# ── 定时刷新（分钟） ──────────────────────────────────────────
REFRESH_INTERVAL=30

# ── 监控面板端口 ──────────────────────────────────────────────
MONITOR_PORT=8080

# ── 代理可用性检测 ────────────────────────────────────────────
# 是否启用代理连通性检测（true/false），默认 true
PROXY_CHECK_ENABLED=true
# 每个代理连通性检测的超时时间（秒），默认 8
PROXY_CHECK_TIMEOUT=8
# 用于检测连通性的测试 URL，默认 http://httpbin.org/ip
PROXY_CHECK_URL=http://httpbin.org/ip
# 并行检测数量，默认 10
PROXY_CHECK_PARALLEL=10

# ── API 安全配置 ────────────────────────────────────────────
# 热重载 API Token（为空则不启用鉴权）
RELOAD_API_TOKEN=
# CORS 允许的来源（逗号分隔），默认 * 即所有
CORS_ORIGINS=*
